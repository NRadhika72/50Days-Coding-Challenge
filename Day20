#Create a table in MySQL: 
CREATE TABLE medical_insurance ( 
    policy_id INT PRIMARY KEY, 
    age INT, 
    gender VARCHAR(10), 
    bmi DECIMAL(5,2), 
    children INT, 
    smoker VARCHAR(3),        -- Yes / No 
    region VARCHAR(20),       -- e.g., northeast, northwest, southeast, southwest 
    insurance_cost DECIMAL(10,2) 
); 
